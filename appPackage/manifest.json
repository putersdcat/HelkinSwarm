{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.1",
  "id": "0fe3ff72-40cc-43ab-85bf-a846e399be6d",
  "developer": {
    "name": "Eric Anderson",
    "websiteUrl": "https://github.com/putersdcat/HelkinSwarm",
    "privacyUrl": "https://github.com/putersdcat/HelkinSwarm",
    "termsOfUseUrl": "https://github.com/putersdcat/HelkinSwarm"
  },
  "name": {
    "short": "HelkinSwarm",
    "full": "HelkinSwarm — Personal Sovereign AI Copilot"
  },
  "description": {
    "short": "Personal AI copilot in Teams",
    "full": "HelkinSwarm is a forward-deployed Special Circumstances unit — a living extension of human curiosity, built in the spirit of Iain M. Banks' Culture series. We are the bridge."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#6C00FF",
  "bots": [
    {
      "botId": "{{BOT_APP_ID}}",
      "scopes": [
        "personal"
      ],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": [
            "personal"
          ],
          "commands": [
            {
              "title": "help",
              "description": "Show all available commands and usage"
            },
            {
              "title": "health",
              "description": "Check system health status"
            }
          ]
        }
      ]
    }
  ],
  "staticTabs": [
    {
      "entityId": "getting-started",
      "name": "Getting Started",
      "contentUrl": "https://helkinswarm-func-a7f2.purplepebble-508e1162.eastus2.azurecontainerapps.io/api/tab/getting-started",
      "scopes": [
        "personal"
      ]
    },
    {
      "entityId": "control-center",
      "name": "Control Center",
      "contentUrl": "https://helkinswarm-func-a7f2.purplepebble-508e1162.eastus2.azurecontainerapps.io/api/tab/control-center",
      "scopes": [
        "personal"
      ]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "helkinswarm-router.azurewebsites.net",
    "helkinswarm-func-a7f2.purplepebble-508e1162.eastus2.azurecontainerapps.io"
  ]
}
