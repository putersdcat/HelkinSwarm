      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('routerStName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('routerStName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('routerStName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), variables('roleStorageTableContributor'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleStorageTableContributor'))]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('routerStName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName'))]"
      ]
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('routerAcrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": false,
        "publicNetworkAccess": "Enabled"
      }
    },
