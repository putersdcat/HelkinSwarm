      "kind": "azurebot",
      "properties": {
        "displayName": "HelkinSwarm",
        "endpoint": "[format('https://{0}.{1}/api/messages', variables('routerFuncName'), reference(resourceId('Microsoft.App/managedEnvironments', variables('routerCaeName')), '2024-03-01').defaultDomain)]",
        "msaAppId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), '2023-01-31').clientId]",
        "msaAppType": "UserAssignedMSI",
        "msaAppMSIResourceId": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName'))]",
        "msaAppTenantId": "[subscription().tenantId]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('routerCaeName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName'))]"
