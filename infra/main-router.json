  "outputs": {
    "routerEndpoint": {
      "type": "string",
      "value": "[format('https://{0}/api/messages', format('{0}.{1}', variables('routerFuncName'), reference(resourceId('Microsoft.App/managedEnvironments', variables('routerCaeName')), '2024-03-01').defaultDomain))]"
    },
    "routerHostName": {
      "type": "string",
      "value": "[format('{0}.{1}', variables('routerFuncName'), reference(resourceId('Microsoft.App/managedEnvironments', variables('routerCaeName')), '2024-03-01').defaultDomain)]"
