      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('routerCaeName'))]",
        "workloadProfileName": "Consumption",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 80,
            "transport": "auto",
            "allowInsecure": false
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('routerAcrName')), '2023-07-01').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName'))]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "helkinswarm-router",
              "image": "mcr.microsoft.com/azure-functions/node:4-node20-appservice",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "AzureWebJobsStorage__accountName",
                  "value": "[variables('routerStName')]"
                },
                {
                  "name": "AzureWebJobsStorage__credential",
                  "value": "managedidentity"
                },
                {
                  "name": "AzureWebJobsStorage__clientId",
                  "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), '2023-01-31').clientId]"
                },
                {
                  "name": "FUNCTIONS_EXTENSION_VERSION",
                  "value": "~4"
                },
                {
                  "name": "FUNCTIONS_WORKER_RUNTIME",
                  "value": "node"
                },
                {
                  "name": "AzureWebJobsFeatureFlags",
                  "value": "EnableWorkerIndexing"
                },
                {
                  "name": "MicrosoftAppId",
                  "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), '2023-01-31').clientId]"
