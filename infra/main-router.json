      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('routerAcrName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('routerAcrName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), variables('roleAcrPull'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleAcrPull'))]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
