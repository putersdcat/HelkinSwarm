    },
    {
      "type": "Microsoft.BotService/botServices/channels",
      "apiVersion": "2022-09-15",
      "name": "[format('{0}/{1}', variables('routerBotName'), 'MsTeamsChannel')]",
      "location": "global",
      "properties": {
        "channelName": "MsTeamsChannel",
        "properties": {
          "isEnabled": true
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.BotService/botServices', variables('routerBotName'))]"
      ]
    },
    {
      "condition": "[parameters('createOAuthConnection')]",
      "type": "Microsoft.BotService/botServices/connections",
      "apiVersion": "2022-09-15",
      "name": "[format('{0}/{1}', variables('routerBotName'), 'GraphOAuth')]",
      "location": "global",
      "properties": {
        "serviceProviderDisplayName": "Azure Active Directory v2",
        "serviceProviderId": "30dd229c-58e3-4a48-bdfd-91ec48eb906c",
        "clientId": "[parameters('delegatedAuthClientId')]",
        "clientSecret": "[parameters('delegatedAuthClientSecret')]",
        "scopes": "User.Read Mail.ReadWrite Calendars.ReadWrite Files.ReadWrite offline_access",
        "parameters": [
          {
            "key": "tenantID",
            "value": "[subscription().tenantId]"
          },
          {
            "key": "clientId",
            "value": "[parameters('delegatedAuthClientId')]"
          },
          {
            "key": "clientSecret",
            "value": "[parameters('delegatedAuthClientSecret')]"
          },
          {
            "key": "scopes",
            "value": "User.Read Mail.ReadWrite Calendars.ReadWrite Files.ReadWrite offline_access"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.BotService/botServices', variables('routerBotName'))]"
      ]
    }
