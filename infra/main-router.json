        "[extensionResourceId(resourceId('Microsoft.Storage/storageAccounts', variables('routerStName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Storage/storageAccounts', variables('routerStName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), variables('roleStorageBlobDataOwner')))]",
        "[extensionResourceId(resourceId('Microsoft.Storage/storageAccounts', variables('routerStName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Storage/storageAccounts', variables('routerStName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), variables('roleStorageQueueContributor')))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('routerAcrName'))]",
        "[resourceId('Microsoft.Insights/components', variables('routerAppiName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('routerCaeName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('routerStName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName'))]",
        "[extensionResourceId(resourceId('Microsoft.Storage/storageAccounts', variables('routerStName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Storage/storageAccounts', variables('routerStName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('routerUamiName')), variables('roleStorageTableContributor')))]"
      ]
