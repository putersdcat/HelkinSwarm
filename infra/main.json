              "query": "customEvents | where name == \"EuResidencyViolation\" or (name == \"LlmCall\" and tostring(customDimensions[\"euMode\"]) == \"true\" and tostring(customDimensions[\"provider\"]) != \"azure-eu\")",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(not(equals(parameters('alertEmail'), '')), createArray(resourceId('Microsoft.Insights/actionGroups', format('helkinswarm-ag-{0}', variables('suffix')))), createArray())]"
        }
