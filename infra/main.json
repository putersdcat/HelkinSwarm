        "[resourceId('Microsoft.Insights/actionGroups', format('helkinswarm-ag-{0}', variables('suffix')))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "helkinswarm-alert-orchestrator-failure",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "HelkinSwarm — Orchestrator Failure",
        "description": "Fires when session orchestrator or overseer fails. 3+ failures in 15 minutes indicates systemic issue.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [
          "[resourceId('Microsoft.Insights/components', variables('appInsName'))]"
        ],
        "criteria": {
          "allOf": [
            {
              "query": "exceptions | where outerMessage contains \"orchestrator\" or outerMessage contains \"Durable\" or outerMessage contains \"overseer\"",
              "timeAggregation": "Count",
              "operator": "GreaterThanOrEqual",
              "threshold": 3
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(not(equals(parameters('alertEmail'), '')), createArray(resourceId('Microsoft.Insights/actionGroups', format('helkinswarm-ag-{0}', variables('suffix')))), createArray())]"
