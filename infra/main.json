      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('helkinswarm-ag-{0}', variables('suffix')))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "helkinswarm-alert-verification-failure",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "HelkinSwarm — High-Risk Action Verification Failure",
        "description": "Fires when a high-risk tool dispatch fails verification. Indicates potential safety pipeline issues.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [
          "[resourceId('Microsoft.Insights/components', variables('appInsName'))]"
        ],
        "criteria": {
          "allOf": [
            {
              "query": "customEvents | where name == \"ToolDispatch\" and tostring(customDimensions[\"riskLevel\"]) in (\"high\", \"critical\") and tostring(customDimensions[\"approved\"]) == \"false\"",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(not(equals(parameters('alertEmail'), '')), createArray(resourceId('Microsoft.Insights/actionGroups', format('helkinswarm-ag-{0}', variables('suffix')))), createArray())]"
        }
