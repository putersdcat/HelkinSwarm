      },
      "properties": {
        "model": {
          "format": "xAI",
          "name": "grok-4-1-fast-non-reasoning",
          "version": "1"
        },
        "raiPolicyName": "Microsoft.DefaultV2",
        "versionUpgradeOption": "NoAutoUpgrade"
      },
      "dependsOn": [
