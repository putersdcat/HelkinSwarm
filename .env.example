# HelkinSwarm — Local Development Settings
# Copy to .env and fill in your values.
# Azure Functions reads local.settings.json for dev; this is reference.

# ── Stamp Identity ──
USER_ALIAS=a7f2

# ── Azure Identity (MSI — no secrets needed in production) ──
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ── Bot Framework ──
MICROSOFT_APP_ID=
MICROSOFT_APP_TYPE=UserAssignedMsi
MICROSOFT_APP_TENANT_ID=

# ── Cosmos DB ──
COSMOS_ENDPOINT=https://helkinswarm-cosmos-a7f2.documents.azure.com:443/

# ── Azure AI Foundry ──
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_CONTENT_SAFETY_ENDPOINT=

# ── LLM Config ──
LLM_PRIMARY_MODEL=gpt-5
LLM_SECONDARY_MODEL=grok-4-1-fast-reasoning
EU_RESIDENCY_MODE=false
LLM_PROVIDER=azure

# ── BYOK (OpenRouter — optional) ──
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_PRIMARY=moonshotai/kimi-k2.5
OPENROUTER_FALLBACK_SECONDARY=moonshotai/kimi-k2.5

# ── OBO / Delegated Identity ──
BOT_OAUTH_CONNECTION_NAME=GraphOAuth
ENTRA_OBO_CLIENT_SECRET=

# ── Observability ──
APPLICATIONINSIGHTS_CONNECTION_STRING=
