# HelkinSwarm — Local Development Environment Variables
# Copy to .env and fill in your values.
# In Azure, these come from Bicep outputs, Key Vault refs, or Container Apps secrets.
# See src/config/envConfig.ts for Zod schema and defaults.

# ── Bot Framework (required) ──
MicrosoftAppId=
MicrosoftAppTenantId=
MICROSOFT_APP_TYPE=UserAssignedMsi

# ── Azure Identity (MSI — no secrets needed in production) ──
AZURE_CLIENT_ID=

# ── Azure AI Foundry ──
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-foundry>.cognitiveservices.azure.com

# ── LLM Config ──
LLM_PRIMARY_MODEL=grok-4-1-fast-reasoning
LLM_SECONDARY_MODEL=grok-4-1-fast-non-reasoning
LLM_FALLBACK_PRIMARY=gpt-5.4-mini
# Optional second-line fallback if you deploy an additional chat-capable backup.
# LLM_FALLBACK_SECONDARY=DeepSeek-V3.2
LLM_EMBEDDING_MODEL=text-embedding-3-large

# ── Cosmos DB ──
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE=helkinswarm

# ── Content Safety ──
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-safety>.cognitiveservices.azure.com

# ── Safety & Residency ──
SAFETY_MODE=confirmation-gated
EU_RESIDENCY_MODE=false

# ── Feature Flags ──
SKILLFORGE_ENABLED=false
DEVLOOP_ENABLED=false

# ── Owner ──
OWNER_USER_ID=

# ── Local Dev Overrides (never set in production) ──
# AZURE_FOUNDRY_OBO_TOKEN=

# ── Observability ──
APPLICATIONINSIGHTS_CONNECTION_STRING=
