{
  "domain": "github",
  "version": "1.0",
  "tools": [
    {
      "name": "github_list_issues",
      "description": "List issues in the HelkinSwarm repository. Supports filtering by state (open/closed/all), labels, milestone, and assignee.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issue events (opened, labeled, closed)"
        },
        {
          "type": "github-projects",
          "action": "Project board automation rules for issue triage"
        }
      ],
      "longTermMemorySchema": [
        "label_taxonomy",
        "active_milestones"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "all"
            ],
            "description": "Filter by issue state (default: open)"
          },
          "labels": {
            "type": "string",
            "description": "Comma-separated list of label names to filter by"
          },
          "milestone": {
            "type": "string",
            "description": "Milestone number or title to filter by"
          },
          "assignee": {
            "type": "string",
            "description": "GitHub username to filter by assignee"
          },
          "per_page": {
            "type": "number",
            "description": "Results per page (max 100, default 30)"
          },
          "page": {
            "type": "number",
            "description": "Page number for pagination (default 1). Use with per_page to retrieve large result sets. Check has_next_page in response to know if more pages exist."
          }
        },
        "required": []
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_search_issues",
      "description": "Full-text search across HelkinSwarm issues and pull requests. Uses GitHub search syntax.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-saved-searches",
          "action": "Saved search queries and custom notification filters"
        }
      ],
      "longTermMemorySchema": [
        "frequent_search_patterns"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query — supports GitHub search syntax (e.g. 'memory in:title label:bug')"
          },
          "per_page": {
            "type": "number",
            "description": "Results per page (max 100, default 30)"
          }
        },
        "required": [
          "query"
        ]
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_get_issue",
      "description": "Get full details of a specific issue by number, including body, labels, milestone, and comments.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [],
      "longTermMemorySchema": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_number": {
            "type": "number",
            "description": "The issue number to retrieve"
          }
        },
        "required": [
          "issue_number"
        ]
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_create_issue",
      "description": "Create a new issue in the HelkinSwarm repository. ALWAYS provide a descriptive body with context, acceptance criteria, and relevant details — never create issues with an empty body.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issues.opened for auto-labeling and triage"
        },
        {
          "type": "issue-templates",
          "action": "Repository issue templates for structured creation"
        }
      ],
      "longTermMemorySchema": [
        "common_labels",
        "issue_template_patterns"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Issue title"
          },
          "body": {
            "type": "string",
            "description": "Issue body (Markdown supported)"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels to apply"
          },
          "milestone": {
            "type": "number",
            "description": "Milestone number to assign"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "GitHub usernames to assign"
          }
        },
        "required": [
          "title",
          "body"
        ]
      },
      "privilegeClass": "create",
      "requiresSubAgent": true
    },
    {
      "name": "github_update_issue",
      "description": "Update an existing issue — change title, body, state, labels, milestone, or assignees.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issues.edited and issues.closed"
        },
        {
          "type": "github-projects",
          "action": "Auto-move cards on state change"
        }
      ],
      "longTermMemorySchema": [
        "workflow_state_patterns"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_number": {
            "type": "number",
            "description": "The issue number to update"
          },
          "title": {
            "type": "string",
            "description": "New title"
          },
          "body": {
            "type": "string",
            "description": "New body"
          },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed"
            ],
            "description": "New state"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels to set (replaces existing)"
          },
          "milestone": {
            "type": "number",
            "description": "Milestone number (null to remove)"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Assignees to set (replaces existing)"
          }
        },
        "required": [
          "issue_number"
        ]
      },
      "privilegeClass": "read-write",
      "requiresSubAgent": false
    },
    {
      "name": "github_add_comment",
      "description": "Add a comment to an existing issue in the HelkinSwarm repository.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issue_comment.created for bot commands"
        }
      ],
      "longTermMemorySchema": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_number": {
            "type": "number",
            "description": "The issue number to comment on"
          },
          "body": {
            "type": "string",
            "description": "Comment body (Markdown supported)"
          }
        },
        "required": [
          "issue_number",
          "body"
        ]
      },
      "privilegeClass": "create",
      "requiresSubAgent": false
    },
    {
      "name": "github_list_milestones",
      "description": "List milestones in the HelkinSwarm repository for prioritization context.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [],
      "longTermMemorySchema": [
        "active_milestone_numbers"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "all"
            ],
            "description": "Filter by state (default: open)"
          }
        },
        "required": []
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    }
  ],
  "shortName": "github",
  "displayName": "GitHub",
  "shortDescription": "Issue tracking, PR management, milestones, and repository operations",
  "iconUrl": "https://helkinswarmtabsst.z20.web.core.windows.net/icons/github.png",
  "deploymentScenario": "personal-user-centric",
  "onboardingMethod": "automatic-agentic",
  "lifecycleRules": "keep-credentials"
}
