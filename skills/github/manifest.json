{
  "domain": "github",
  "version": "1.0",
  "tools": [
    {
      "name": "github_list_issues",
      "description": "List issues in the HelkinSwarm repository. Supports filtering by state (open/closed/all), labels, milestone, and assignee.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issue events (opened, labeled, closed)"
        },
        {
          "type": "github-projects",
          "action": "Project board automation rules for issue triage"
        }
      ],
      "longTermMemorySchema": [
        "label_taxonomy",
        "active_milestones"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "all"
            ],
            "description": "Filter by issue state (default: open)"
          },
          "labels": {
            "type": "string",
            "description": "Comma-separated list of label names to filter by"
          },
          "milestone": {
            "type": "string",
            "description": "Milestone number or title to filter by"
          },
          "assignee": {
            "type": "string",
            "description": "GitHub username to filter by assignee"
          },
          "per_page": {
            "type": "number",
            "description": "Results per page (max 100, default 30)"
          },
          "page": {
            "type": "number",
            "description": "Page number for pagination (default 1). Use with per_page to retrieve large result sets. Check has_next_page in response to know if more pages exist."
          }
        },
        "required": []
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_search_issues",
      "description": "Full-text search across HelkinSwarm issues and pull requests. Uses GitHub search syntax.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-saved-searches",
          "action": "Saved search queries and custom notification filters"
        }
      ],
      "longTermMemorySchema": [
        "frequent_search_patterns"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query — supports GitHub search syntax (e.g. 'memory in:title label:bug')"
          },
          "per_page": {
            "type": "number",
            "description": "Results per page (max 100, default 30)"
          }
        },
        "required": [
          "query"
        ]
      },
      "aliases": [
        "search github issues",
        "find issue"
      ],
      "discoveryTerms": [
        "issue search",
        "pr search",
        "repository backlog"
      ],
      "useWhen": [
        "the user needs to find issues or pull requests before reading or updating them"
      ],
      "typicalInputs": [
        "memory in:title label:bug",
        "is:pr discovery layer"
      ],
      "returnsSummaryShape": "matching issue or pull-request summaries",
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_get_issue",
      "description": "Get full details of a specific issue by number, including body, labels, milestone, and comments.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [],
      "longTermMemorySchema": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_number": {
            "type": "number",
            "description": "The issue number to retrieve"
          }
        },
        "required": [
          "issue_number"
        ]
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_create_issue",
      "description": "Create a new issue in the HelkinSwarm repository. ALWAYS provide a descriptive body with context, acceptance criteria, and relevant details — never create issues with an empty body. The user MUST be confirmed via the safety pipeline before this fires; never invoke from probe/ping/diagnostic phrasing or implicit intent (#665, #703).",
      "risk": "medium",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": true,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issues.opened for auto-labeling and triage"
        },
        {
          "type": "issue-templates",
          "action": "Repository issue templates for structured creation"
        }
      ],
      "longTermMemorySchema": [
        "common_labels",
        "issue_template_patterns"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Issue title"
          },
          "body": {
            "type": "string",
            "description": "Issue body (Markdown supported)"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels to apply"
          },
          "milestone": {
            "type": "number",
            "description": "Milestone number to assign"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "GitHub usernames to assign"
          }
        },
        "required": [
          "title",
          "body"
        ]
      },
      "privilegeClass": "create",
      "requiresSubAgent": true
    },
    {
      "name": "github_update_issue",
      "description": "Update an existing issue — change title, body, state, labels, milestone, or assignees.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issues.edited and issues.closed"
        },
        {
          "type": "github-projects",
          "action": "Auto-move cards on state change"
        }
      ],
      "longTermMemorySchema": [
        "workflow_state_patterns"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_number": {
            "type": "number",
            "description": "The issue number to update"
          },
          "title": {
            "type": "string",
            "description": "New title"
          },
          "body": {
            "type": "string",
            "description": "New body"
          },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed"
            ],
            "description": "New state"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels to set (replaces existing)"
          },
          "milestone": {
            "type": "number",
            "description": "Milestone number (null to remove)"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Assignees to set (replaces existing)"
          }
        },
        "required": [
          "issue_number"
        ]
      },
      "privilegeClass": "read-write",
      "requiresSubAgent": false
    },
    {
      "name": "github_add_comment",
      "description": "Add a comment to an existing issue in the HelkinSwarm repository.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-actions",
          "action": "Workflow triggers on issue_comment.created for bot commands"
        }
      ],
      "longTermMemorySchema": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_number": {
            "type": "number",
            "description": "The issue number to comment on"
          },
          "body": {
            "type": "string",
            "description": "Comment body (Markdown supported)"
          }
        },
        "required": [
          "issue_number",
          "body"
        ]
      },
      "privilegeClass": "create",
      "requiresSubAgent": false
    },
    {
      "name": "github_push_files",
      "description": "Create or update multiple files directly in the HelkinSwarm repository on a target branch (default: main). Use for controlled promotion of generated artifacts into tracked repository content.",
      "risk": "high",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": true,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [
        {
          "type": "github-contents-api",
          "action": "createOrUpdateFiles"
        }
      ],
      "longTermMemorySchema": [
        "promotion_commit_patterns"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "branch": {
            "type": "string",
            "description": "Branch to write to (default: main)"
          },
          "message": {
            "type": "string",
            "description": "Commit message used for each file write"
          },
          "files": {
            "type": "array",
            "description": "Files to create or update in the repository",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "description": "Repository-relative file path"
                },
                "content": {
                  "type": "string",
                  "description": "UTF-8 file content"
                }
              },
              "required": [
                "path",
                "content"
              ]
            }
          }
        },
        "required": [
          "message",
          "files"
        ]
      },
      "privilegeClass": "create",
      "requiresSubAgent": true
    },
    {
      "name": "github_list_milestones",
      "description": "List milestones in the HelkinSwarm repository for prioritization context.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [],
      "longTermMemorySchema": [
        "active_milestone_numbers"
      ],
      "inputSchema": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "open",
              "closed",
              "all"
            ],
            "description": "Filter by state (default: open)"
          }
        },
        "required": []
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_list_workflow_runs",
      "description": "List recent GitHub Actions workflow runs for the HelkinSwarm repository. Returns run status, conclusion, workflow name, trigger event, elapsed time, and URL. Useful for checking deploy status, CI health, and Actions billing.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [],
      "longTermMemorySchema": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number",
            "description": "Number of recent runs to return (1–30, default 10)"
          },
          "workflow_id": {
            "type": "string",
            "description": "Optional: filter by workflow file name (e.g. deploy-stamp.yml) or workflow ID"
          },
          "branch": {
            "type": "string",
            "description": "Optional: filter by branch name (e.g. main)"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "in_progress", "completed", "waiting", "requested", "pending"],
            "description": "Optional: filter by run status"
          }
        },
        "required": []
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    },
    {
      "name": "github_get_workflow_run",
      "description": "Get full details for a specific GitHub Actions workflow run by its run ID, including billable time breakdown by operating system (Linux/macOS/Windows). Useful for costing individual deploys or debugging failed runs.",
      "risk": "low",
      "dataSensitivity": "non-pii",
      "allowedModelLane": "any",
      "requiresConfirmation": false,
      "requiresExecutor": false,
      "externalAutomationCapabilities": [],
      "longTermMemorySchema": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "number",
            "description": "The numeric ID of the workflow run"
          }
        },
        "required": ["run_id"]
      },
      "privilegeClass": "read-only",
      "requiresSubAgent": false
    }
  ],
  "shortName": "github",
  "displayName": "GitHub",
  "shortDescription": "Issue tracking, PR management, milestones, workflow runs, and repository operations",
  "discoveryHints": [
    "issues",
    "pull requests",
    "milestones",
    "repository backlog",
    "GitHub Actions",
    "workflow runs",
    "CI/CD",
    "deployment runs",
    "Actions billing",
    "billable minutes"
  ],
  "orchestratorUseCases": [
    "read and search issues or pull requests",
    "create, update, and comment on repository work items",
    "check GitHub Actions workflow run status, history, and billable minutes"
  ],
  "recommendedEntryTools": [
    "github_search_issues",
    "github_list_issues",
    "github_get_issue",
    "github_list_workflow_runs"
  ],
  "iconUrl": "https://helkinswarmtabsst.z20.web.core.windows.net/icons/github.png",
  "deploymentScenario": "personal-user-centric",
  "onboardingMethod": "automatic-agentic",
  "lifecycleRules": "keep-credentials"
}
